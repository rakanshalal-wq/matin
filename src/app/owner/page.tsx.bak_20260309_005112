'use client';
import { useState, useEffect, useCallback } from 'react';
import { useRouter } from 'next/navigation';

const G = '#C9A227', G2 = '#E8C547';
const DARK = '#060C18', CARD = 'rgba(255,255,255,0.03)', BORDER = 'rgba(255,255,255,0.07)';

const getAuthHeaders = (): Record<string, string> => {
  try {
    const token = typeof window !== 'undefined' ? localStorage.getItem('matin_token') : null;
    if (token) return { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token };
  } catch {}
  return { 'Content-Type': 'application/json' };
};
const api = (url: string, opts: RequestInit = {}) =>
  fetch(url, { credentials: 'include', headers: { ...getAuthHeaders() }, ...opts });
type Tab = 'overview' | 'schools' | 'permissions' | 'plans' | 'subscriptions' | 'users' | 'ads' | 'finance' | 'analytics' | 'support' | 'notifications' | 'security' | 'settings';

const TABS: { id: Tab; icon: string; label: string }[] = [
  { id: 'overview',      icon: '📊', label: 'نظرة عامة' },
  { id: 'schools',       icon: '🏫', label: 'المؤسسات' },
  { id: 'permissions',   icon: '🔑', label: 'الصلاحيات' },
  { id: 'plans',         icon: '📦', label: 'الباقات' },
  { id: 'subscriptions', icon: '💎', label: 'الاشتراكات' },
  { id: 'users',         icon: '👥', label: 'المستخدمون' },
  { id: 'ads',           icon: '📢', label: 'الإعلانات' },
  { id: 'finance',       icon: '💰', label: 'المالية' },
  { id: 'analytics',     icon: '📈', label: 'التحليلات' },
  { id: 'support',       icon: '💬', label: 'الدعم' },
  { id: 'notifications', icon: '🔔', label: 'الإشعارات' },
  { id: 'security',      icon: '🔐', label: 'الأمان' },
  { id: 'settings',      icon: '⚙️', label: 'الإعدادات' },
];

const ROLES: { value: string; label: string; color: string }[] = [
  { value: 'owner',   label: 'مالك مدرسة',  color: '#8B5CF6' },
  { value: 'admin',   label: 'مدير مدرسة',  color: '#3B82F6' },
  { value: 'teacher', label: 'معلم',         color: '#10B981' },
  { value: 'student', label: 'طالب',         color: '#EC4899' },
  { value: 'parent',  label: 'ولي أمر',      color: '#F59E0B' },
];

function Toast({ msg, ok }: { msg: string; ok: boolean }) {
  return (
    <div style={{
      position: 'fixed', top: 24, left: '50%', transform: 'translateX(-50%)', zIndex: 9999,
      background: ok ? 'rgba(16,185,129,0.95)' : 'rgba(239,68,68,0.95)',
      color: 'white', padding: '12px 32px', borderRadius: 12, fontWeight: 700, fontSize: 14,
      boxShadow: '0 8px 40px rgba(0,0,0,0.5)', backdropFilter: 'blur(12px)',
      border: `1px solid ${ok ? 'rgba(16,185,129,0.4)' : 'rgba(239,68,68,0.4)'}`,
      minWidth: 200, textAlign: 'center'
    }}>
      {msg}
    </div>
  );
}

function StatCard({ icon, label, value, sub, color, onClick }: any) {
  return (
    <div onClick={onClick} style={{
      background: CARD, border: `1px solid ${BORDER}`, borderTop: `2px solid ${color}44`,
      borderRadius: 16, padding: '20px 18px', cursor: onClick ? 'pointer' : 'default', transition: 'all 0.2s'
    }}
      onMouseEnter={e => { if (onClick) (e.currentTarget as HTMLElement).style.background = 'rgba(255,255,255,0.06)'; }}
      onMouseLeave={e => { if (onClick) (e.currentTarget as HTMLElement).style.background = CARD; }}>
      <div style={{ fontSize: 28, marginBottom: 10 }}>{icon}</div>
      <div style={{ fontSize: 26, fontWeight: 800, color, marginBottom: 4 }}>{typeof value === 'number' ? value.toLocaleString('ar-SA') : value}</div>
      <div style={{ fontSize: 12, color: 'rgba(255,255,255,0.5)', fontWeight: 600, marginBottom: 2 }}>{label}</div>
      {sub && <div style={{ fontSize: 11, color: 'rgba(255,255,255,0.3)' }}>{sub}</div>}
    </div>
  );
}

function SectionHeader({ title, sub, btn, onBtn }: any) {
  return (
    <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'flex-start', marginBottom: 24, flexWrap: 'wrap', gap: 12 }}>
      <div>
        <h2 style={{ fontSize: 22, fontWeight: 800, margin: 0, color: 'white' }}>{title}</h2>
        {sub && <p style={{ color: 'rgba(255,255,255,0.4)', fontSize: 13, margin: '4px 0 0' }}>{sub}</p>}
      </div>
      {btn && <button onClick={onBtn} style={{ background: `linear-gradient(135deg,${G},${G2})`, color: '#060C18', padding: '10px 22px', borderRadius: 10, border: 'none', fontWeight: 700, cursor: 'pointer', fontSize: 14 }}>{btn}</button>}
    </div>
  );
}

function Badge({ label, color, bg }: { label: string; color: string; bg: string }) {
  return <span style={{ background: bg, color, padding: '3px 10px', borderRadius: 6, fontSize: 11, fontWeight: 700 }}>{label}</span>;
}

function statusBadge(s: string) {
  const map: any = { ACTIVE: '#10B981', active: '#10B981', approved: '#10B981', TRIAL: '#F59E0B', trial: '#F59E0B', pending: '#F59E0B', SUSPENDED: '#EF4444', suspended: '#EF4444', rejected: '#EF4444', inactive: '#6B7280', expired: '#6B7280' };
  const labels: any = { ACTIVE: 'نشط', active: 'نشط', approved: 'مفعّل', TRIAL: 'تجريبي', trial: 'تجريبي', pending: 'معلق', SUSPENDED: 'موقوف', suspended: 'موقوف', rejected: 'مرفوض', inactive: 'غير نشط', expired: 'منتهي' };
  const c = map[s] || '#6B7280';
  return <Badge label={labels[s] || s} color={c} bg={`${c}18`} />;
}

function Modal({ title, onClose, children, wide }: any) {
  return (
    <div style={{ position: 'fixed', inset: 0, background: 'rgba(0,0,0,0.85)', display: 'flex', alignItems: 'center', justifyContent: 'center', zIndex: 1000, padding: 20 }}>
      <div style={{ background: '#0D1B2A', border: `1px solid ${BORDER}`, borderRadius: 20, padding: 32, width: '100%', maxWidth: wide ? 700 : 520, maxHeight: '88vh', overflowY: 'auto' }}>
        <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: 24 }}>
          <h3 style={{ color: 'white', fontWeight: 800, fontSize: 18, margin: 0 }}>{title}</h3>
          <button onClick={onClose} style={{ background: 'none', border: 'none', color: 'rgba(255,255,255,0.4)', fontSize: 22, cursor: 'pointer' }}>✕</button>
        </div>
        {children}
      </div>
    </div>
  );
}

function Input({ label, value, onChange, type = 'text', placeholder = '', readOnly = false }: any) {
  return (
    <div style={{ marginBottom: 14 }}>
      <label style={{ color: 'rgba(255,255,255,0.5)', fontSize: 12, fontWeight: 600, display: 'block', marginBottom: 6 }}>{label}</label>
      <input type={type} value={value} onChange={e => onChange && onChange(e.target.value)} placeholder={placeholder} readOnly={readOnly}
        style={{ width: '100%', background: readOnly ? 'rgba(255,255,255,0.02)' : 'rgba(255,255,255,0.05)', border: `1px solid ${BORDER}`, borderRadius: 10, padding: '10px 14px', color: readOnly ? 'rgba(255,255,255,0.4)' : 'white', fontSize: 13, outline: 'none', boxSizing: 'border-box' }} />
    </div>
  );
}

function Select({ label, value, onChange, options }: any) {
  return (
    <div style={{ marginBottom: 14 }}>
      <label style={{ color: 'rgba(255,255,255,0.5)', fontSize: 12, fontWeight: 600, display: 'block', marginBottom: 6 }}>{label}</label>
      <select value={value} onChange={e => onChange(e.target.value)}
        style={{ width: '100%', background: '#0D1B2A', border: `1px solid ${BORDER}`, borderRadius: 10, padding: '10px 14px', color: 'white', fontSize: 13, outline: 'none', boxSizing: 'border-box' }}>
        {options.map((o: any) => <option key={o.value} value={o.value}>{o.label}</option>)}
      </select>
    </div>
  );
}

function SaveBtn({ label, onClick, loading: ld }: any) {
  return (
    <button onClick={onClick} disabled={ld} style={{ width: '100%', background: ld ? 'rgba(201,162,39,0.4)' : `linear-gradient(135deg,${G},${G2})`, color: '#060C18', padding: '13px', borderRadius: 10, border: 'none', fontWeight: 800, cursor: ld ? 'not-allowed' : 'pointer', fontSize: 14, marginTop: 8 }}>
      {ld ? '⏳ جاري الحفظ...' : label}
    </button>
  );
}

function EmptyState({ icon, msg }: any) {
  return (
    <div style={{ textAlign: 'center', padding: '60px 20px', background: CARD, border: `1px solid ${BORDER}`, borderRadius: 16 }}>
      <div style={{ fontSize: 52, marginBottom: 16 }}>{icon}</div>
      <div style={{ color: 'rgba(255,255,255,0.3)', fontSize: 15 }}>{msg}</div>
    </div>
  );
}

function SearchBar({ value, onChange, placeholder }: any) {
  return (
    <input value={value} onChange={e => onChange(e.target.value)} placeholder={placeholder || '🔍 بحث...'}
      style={{ flex: 1, minWidth: 200, background: 'rgba(255,255,255,0.05)', border: `1px solid ${BORDER}`, borderRadius: 10, padding: '10px 14px', color: 'white', fontSize: 13, outline: 'none' }} />
  );
}

function FilterBtn({ label, active, onClick }: any) {
  return (
    <button onClick={onClick} style={{ padding: '8px 16px', borderRadius: 8, border: `1px solid ${active ? G : BORDER}`, background: active ? `${G}18` : 'transparent', color: active ? G : 'rgba(255,255,255,0.4)', cursor: 'pointer', fontSize: 12, fontWeight: 600 }}>
      {label}
    </button>
  );
}

function ActionBtn({ label, color, onClick }: any) {
  const hex = color || '#3B82F6';
  return (
    <button onClick={onClick} style={{ background: `${hex}18`, border: `1px solid ${hex}33`, color: hex, padding: '4px 10px', borderRadius: 6, cursor: 'pointer', fontSize: 11, fontWeight: 600, whiteSpace: 'nowrap' }}>
      {label}
    </button>
  );
}

function TableHeader({ cols }: { cols: string[] }) {
  return (
    <div style={{ display: 'grid', gridTemplateColumns: cols.map(() => '1fr').join(' '), padding: '12px 20px', background: 'rgba(255,255,255,0.04)', borderBottom: `1px solid ${BORDER}` }}>
      {cols.map((h, i) => <span key={i} style={{ color: 'rgba(255,255,255,0.35)', fontSize: 11, fontWeight: 700 }}>{h}</span>)}
    </div>
  );
}

// ══════════════════════════════════════════════════════════════════
export default function SuperAdminDashboard() {
  const router = useRouter();
  const [me, setMe] = useState<any>(null);
  const [tab, setTab] = useState<Tab>('overview');
  const [loading, setLoading] = useState(true);
  const [saving, setSaving] = useState(false);
  const [toast, setToast] = useState<{ msg: string; ok: boolean } | null>(null);
  const [sidebarOpen, setSidebarOpen] = useState(true);

  // Data
  const [stats, setStats] = useState<any>({});
  const [schools, setSchools] = useState<any[]>([]);
  const [users, setUsers] = useState<any[]>([]);
  const [plans, setPlans] = useState<any[]>([]);
  const [ads, setAds] = useState<any[]>([]);
  const [subs, setSubs] = useState<any[]>([]);
  const [leads, setLeads] = useState<any[]>([]);
  const [support, setSupport] = useState<any[]>([]);
  const [actLog, setActLog] = useState<any[]>([]);
  const [permissions, setPermissions] = useState<any[]>([]);
  const [settings, setSettings] = useState<any>({});

  // Modals
  const [schoolModal, setSchoolModal] = useState(false);
  const [planModal, setPlanModal] = useState(false);
  const [adModal, setAdModal] = useState(false);
  const [assignPlanModal, setAssignPlanModal] = useState<any>(null); // school object
  const [editPermModal, setEditPermModal] = useState<any>(null); // user object
  const [editItem, setEditItem] = useState<any>(null);
  const [notifModal, setNotifModal] = useState(false);

  // Forms
  const [sf, setSf] = useState({ name_ar: '', name: '', email: '', phone: '', city: '', status: 'TRIAL' });
  const [pf, setPf] = useState({ name_ar: '', price_monthly: '', price_yearly: '', max_students: '500', max_teachers: '20', features: '', is_active: true });
  const [af, setAf] = useState({ title: '', image_url: '', click_url: '', position: 'top', priority: '1', start_date: '', end_date: '' });
  const [assignPlanForm, setAssignPlanForm] = useState({ plan_id: '', duration_months: '12' });
  const [editPermForm, setEditPermForm] = useState({ role: '', status: '', is_active: true });
  const [notifForm, setNotifForm] = useState({ title: '', body: '', target: 'all' });
  const [settingsForm, setSettingsForm] = useState<any>({});

  // Filters
  const [schoolSearch, setSchoolSearch] = useState('');
  const [schoolStatus, setSchoolStatus] = useState('all');
  const [userSearch, setUserSearch] = useState('');
  const [userRole, setUserRole] = useState('all');
  const [permSearch, setPermSearch] = useState('');
  const [permRole, setPermRole] = useState('all');
  const [subsSearch, setSubsSearch] = useState('');

  const showToast = (msg: string, ok = true) => {
    setToast({ msg, ok });
    setTimeout(() => setToast(null), 3500);
  };

  // ── Fetch ──────────────────────────────────────────────────────
  const fetchStats = async () => { try { const r = await api('/api/dashboard-stats'); const d = await r.json(); setStats(d); } catch {} };
  const fetchSchools = async () => { try { const r = await api('/api/schools'); const d = await r.json(); setSchools(Array.isArray(d) ? d : []); } catch {} };
  const fetchUsers = async () => { try { const r = await api('/api/users'); const d = await r.json(); setUsers(Array.isArray(d) ? d : []); } catch {} };
  const fetchPlans = async () => { try { const r = await api('/api/plans'); const d = await r.json(); setPlans(Array.isArray(d) ? d : (Array.isArray(d?.data) ? d.data : [])); } catch {} };
  const fetchAds = async () => { try { const r = await api('/api/ads'); const d = await r.json(); setAds(Array.isArray(d) ? d : (Array.isArray(d?.ads) ? d.ads : [])); } catch {} };
  const fetchSubs = async () => { try { const r = await api('/api/subscriptions'); const d = await r.json(); setSubs(Array.isArray(d) ? d : []); } catch {} };
  const fetchLeads = async () => { try { const r = await api('/api/leads'); const d = await r.json(); setLeads(Array.isArray(d) ? d : []); } catch {} };
  const fetchSupport = async () => { try { const r = await api('/api/support'); const d = await r.json(); setSupport(Array.isArray(d) ? d : []); } catch {} };
  const fetchActLog = async () => { try { const r = await api('/api/activity-log'); const d = await r.json(); setActLog(Array.isArray(d) ? d : []); } catch {} };
  const fetchPermissions = async () => { try { const r = await api('/api/permissions'); const d = await r.json(); setPermissions(Array.isArray(d) ? d : []); } catch {} };
  const fetchSettings = async () => { try { const r = await api('/api/platform-settings'); const d = await r.json(); setSettings(d || {}); setSettingsForm(d || {}); } catch {} };

  useEffect(() => {
    const init = async () => {
      try {
        const r = await api('/api/auth/me');
        if (!r.ok) { router.push('/login'); return; }
        const u = await r.json();
        const userData = u?.user || u;
        if (userData?.role !== 'super_admin') { router.push('/login'); return; }
        setMe(userData);
        await Promise.all([
          fetchStats(), fetchSchools(), fetchUsers(), fetchPlans(),
          fetchAds(), fetchSubs(), fetchLeads(), fetchSupport(),
          fetchActLog(), fetchPermissions(), fetchSettings(),
        ]);
      } catch { router.push('/login'); }
      finally { setLoading(false); }
    };
    init();
  }, []);

  // ── School Actions ─────────────────────────────────────────────
  const saveSchool = async () => {
    if (!sf.name_ar) { showToast('اسم المؤسسة مطلوب', false); return; }
    setSaving(true);
    try {
      const method = editItem ? 'PUT' : 'POST';
      const body = editItem ? { id: editItem.id, ...sf } : sf;
      const r = await api('/api/schools', { method, body: JSON.stringify(body) });
      if (!r.ok) { showToast('فشل الحفظ', false); return; }
      showToast(editItem ? 'تم تحديث المؤسسة ✅' : 'تمت إضافة المؤسسة ✅');
      setSchoolModal(false); setEditItem(null);
      setSf({ name_ar: '', name: '', email: '', phone: '', city: '', status: 'TRIAL' });
      fetchSchools();
    } catch { showToast('خطأ في الاتصال', false); }
    finally { setSaving(false); }
  };

  const changeSchoolStatus = async (id: string, status: string) => {
    try {
      await api('/api/schools', { method: 'PUT', body: JSON.stringify({ id, status }) });
      fetchSchools();
      showToast(status === 'ACTIVE' ? 'تم تفعيل المؤسسة ✅' : status === 'SUSPENDED' ? 'تم إيقاف المؤسسة' : 'تم التحديث');
    } catch { showToast('خطأ', false); }
  };

  const deleteSchool = async (id: string) => {
    if (!confirm('حذف المؤسسة؟ سيتم حذف جميع بياناتها. لا يمكن التراجع.')) return;
    try { await api(`/api/schools?id=${id}`, { method: 'DELETE' }); fetchSchools(); showToast('تم حذف المؤسسة'); } catch { showToast('خطأ', false); }
  };

  // ── Assign Plan to School ──────────────────────────────────────
  const assignPlan = async () => {
    if (!assignPlanForm.plan_id) { showToast('اختر الباقة', false); return; }
    setSaving(true);
    try {
      const r = await api('/api/plans', {
        method: 'PUT',
        body: JSON.stringify({ action: 'assign_to_school', plan_id: assignPlanForm.plan_id, school_id: assignPlanModal.id, duration_months: assignPlanForm.duration_months })
      });
      const d = await r.json();
      if (!r.ok) { showToast(d.error || 'فشل التعيين', false); return; }
      showToast('تم تعيين الباقة للمؤسسة ✅');
      setAssignPlanModal(null);
      setAssignPlanForm({ plan_id: '', duration_months: '12' });
      fetchSchools(); fetchSubs();
    } catch { showToast('خطأ', false); }
    finally { setSaving(false); }
  };

  // ── Plan Actions ───────────────────────────────────────────────
  const savePlan = async () => {
    if (!pf.name_ar) { showToast('اسم الباقة مطلوب', false); return; }
    setSaving(true);
    try {
      const method = editItem ? 'PUT' : 'POST';
      const body = {
        ...(editItem ? { id: editItem.id } : {}),
        name: pf.name_ar, name_ar: pf.name_ar,
        price_monthly: parseFloat(pf.price_monthly) || 0,
        price_yearly: parseFloat(pf.price_yearly) || 0,
        max_students: parseInt(pf.max_students) || 500,
        max_teachers: parseInt(pf.max_teachers) || 20,
        features: pf.features.split('\n').filter(Boolean),
        is_active: pf.is_active,
      };
      const r = await api('/api/plans', { method, body: JSON.stringify(body) });
      if (!r.ok) { showToast('فشل الحفظ', false); return; }
      showToast(editItem ? 'تم تحديث الباقة ✅' : 'تمت إضافة الباقة ✅');
      setPlanModal(false); setEditItem(null);
      setPf({ name_ar: '', price_monthly: '', price_yearly: '', max_students: '500', max_teachers: '20', features: '', is_active: true });
      fetchPlans();
    } catch { showToast('خطأ', false); }
    finally { setSaving(false); }
  };

  const togglePlan = async (plan: any) => {
    try {
      await api('/api/plans', { method: 'PUT', body: JSON.stringify({ id: plan.id, name: plan.name, name_ar: plan.name_ar, price_monthly: plan.price_monthly, price_yearly: plan.price_yearly, max_students: plan.max_students, max_teachers: plan.max_teachers, features: plan.features, is_active: !plan.is_active }) });
      fetchPlans();
      showToast(plan.is_active ? 'تم تعطيل الباقة' : 'تم تفعيل الباقة ✅');
    } catch { showToast('خطأ', false); }
  };

  const deletePlan = async (id: any) => {
    if (!confirm('حذف الباقة؟')) return;
    try {
      const r = await api(`/api/plans?id=${id}`, { method: 'DELETE' });
      const d = await r.json();
      if (!r.ok) { showToast(d.error || 'فشل الحذف', false); return; }
      fetchPlans(); showToast('تم حذف الباقة');
    } catch { showToast('خطأ', false); }
  };

  // ── Subscription Actions ───────────────────────────────────────
  const changeSubStatus = async (id: any, status: string) => {
    try {
      await api('/api/subscriptions', { method: 'PUT', body: JSON.stringify({ id, status }) });
      fetchSubs(); showToast('تم تحديث الاشتراك ✅');
    } catch { showToast('خطأ', false); }
  };

  const deleteSub = async (id: any) => {
    if (!confirm('حذف الاشتراك؟')) return;
    try { await api(`/api/subscriptions?id=${id}`, { method: 'DELETE' }); fetchSubs(); showToast('تم الحذف'); } catch { showToast('خطأ', false); }
  };

  // ── Permission Actions ─────────────────────────────────────────
  const openEditPerm = (u: any) => {
    setEditPermModal(u);
    setEditPermForm({ role: u.role, status: u.status || 'active', is_active: u.is_active !== false });
  };

  const savePermission = async () => {
    if (!editPermModal) return;
    setSaving(true);
    try {
      const r = await api('/api/permissions', {
        method: 'PUT',
        body: JSON.stringify({ id: editPermModal.id, role: editPermForm.role, status: editPermForm.status, is_active: editPermForm.is_active })
      });
      const d = await r.json();
      if (!r.ok) { showToast(d.error || 'فشل', false); return; }
      showToast('تم تحديث الصلاحيات ✅');
      setEditPermModal(null);
      fetchPermissions(); fetchUsers();
    } catch { showToast('خطأ', false); }
    finally { setSaving(false); }
  };

  const quickToggleUser = async (u: any) => {
    const newStatus = (u.status === 'active' || u.is_active) ? 'suspended' : 'active';
    const newActive = newStatus === 'active';
    try {
      await api('/api/permissions', { method: 'PUT', body: JSON.stringify({ id: u.id, status: newStatus, is_active: newActive }) });
      fetchPermissions();
      showToast(newActive ? `تم تفعيل ${u.name} ✅` : `تم إيقاف ${u.name}`);
    } catch { showToast('خطأ', false); }
  };

  const deleteUserPerm = async (u: any) => {
    if (!confirm(`حذف المستخدم "${u.name}"؟ لا يمكن التراجع.`)) return;
    try {
      const r = await api(`/api/permissions?id=${u.id}`, { method: 'DELETE' });
      const d = await r.json();
      if (!r.ok) { showToast(d.error || 'فشل', false); return; }
      fetchPermissions(); showToast('تم حذف المستخدم');
    } catch { showToast('خطأ', false); }
  };

  // ── User Actions ───────────────────────────────────────────────
