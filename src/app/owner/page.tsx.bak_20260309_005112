    const match = (s.school_name || s.school_name_ar || '').toLowerCase().includes(subsSearch.toLowerCase()) || (s.owner_name || '').toLowerCase().includes(subsSearch.toLowerCase());
    return match;
  });

  const timeAgo = (d: string) => {
    if (!d) return '—';
    const diff = Date.now() - new Date(d).getTime();
    const m = Math.floor(diff / 60000);
    if (m < 1) return 'الآن'; if (m < 60) return `منذ ${m}د`;
    const h = Math.floor(m / 60); if (h < 24) return `منذ ${h}س`;
    return `منذ ${Math.floor(h / 24)} يوم`;
