            <div style={{ background: CARD, border: `1px solid ${BORDER}`, borderRadius: 16, overflow: 'hidden', marginBottom: 20 }}>
              <div style={{ padding: '16px 20px', borderBottom: `1px solid ${BORDER}`, fontWeight: 700 }}>📋 سجل النشاط</div>
              {actLog.slice(0, 20).map((a, i) => (
                <div key={i} style={{ display: 'flex', justifyContent: 'space-between', padding: '12px 20px', borderBottom: `1px solid ${BORDER}`, alignItems: 'center' }}>
                  <div>
                    <div style={{ fontSize: 13, fontWeight: 600 }}>{a.action || a.description || a.type || '—'}</div>
                    <div style={{ fontSize: 11, color: 'rgba(255,255,255,0.3)' }}>{a.user_name || a.email || '—'}</div>
                  </div>
                  <span style={{ color: 'rgba(255,255,255,0.3)', fontSize: 12 }}>{timeAgo(a.created_at)}</span>
                </div>
              ))}
              {actLog.length === 0 && <div style={{ textAlign: 'center', padding: 40, color: 'rgba(255,255,255,0.3)' }}>لا توجد سجلات</div>}
            </div>
          </div>
        )}

        {/* ════ الإعدادات ════ */}
        {tab === 'settings' && (
          <div>
            <SectionHeader title="⚙️ إعدادات المنصة" sub="الإعدادات العامة لمنصة متين" />
            <div style={{ background: CARD, border: `1px solid ${BORDER}`, borderRadius: 16, padding: 28, maxWidth: 600 }}>
              <Input label="اسم المنصة" value={settingsForm.platform_name || 'متين'} onChange={(v: string) => setSettingsForm((f: any) => ({ ...f, platform_name: v }))} />
              <Input label="البريد الإلكتروني للدعم" value={settingsForm.support_email || ''} onChange={(v: string) => setSettingsForm((f: any) => ({ ...f, support_email: v }))} type="email" />
              <Input label="رقم الدعم الفني" value={settingsForm.support_phone || ''} onChange={(v: string) => setSettingsForm((f: any) => ({ ...f, support_phone: v }))} />
              <Input label="رابط الموقع" value={settingsForm.website_url || ''} onChange={(v: string) => setSettingsForm((f: any) => ({ ...f, website_url: v }))} />
              <SaveBtn label="💾 حفظ الإعدادات" onClick={saveSettings} loading={saving} />
            </div>
          </div>
        )}

      </div>

      {/* ══════════════════════════ MODALS ══════════════════════════ */}

      {/* Modal: إضافة/تعديل مؤسسة */}
      {schoolModal && (
        <Modal title={editItem ? '✏️ تعديل المؤسسة' : '🏫 إضافة مؤسسة جديدة'} onClose={() => { setSchoolModal(false); setEditItem(null); }}>
          <Input label="اسم المؤسسة (عربي) *" value={sf.name_ar} onChange={(v: string) => setSf(f => ({ ...f, name_ar: v }))} placeholder="مثال: مدرسة النور الأهلية" />
          <Input label="اسم المؤسسة (إنجليزي)" value={sf.name} onChange={(v: string) => setSf(f => ({ ...f, name: v }))} placeholder="Al Noor School" />
          <Input label="البريد الإلكتروني" value={sf.email} onChange={(v: string) => setSf(f => ({ ...f, email: v }))} type="email" />
          <Input label="رقم الهاتف" value={sf.phone} onChange={(v: string) => setSf(f => ({ ...f, phone: v }))} />
          <Input label="المدينة" value={sf.city} onChange={(v: string) => setSf(f => ({ ...f, city: v }))} placeholder="الرياض" />
          <Select label="الحالة" value={sf.status} onChange={(v: string) => setSf(f => ({ ...f, status: v }))}
            options={[{ value: 'TRIAL', label: 'تجريبي' }, { value: 'ACTIVE', label: 'نشط' }, { value: 'SUSPENDED', label: 'موقوف' }]} />
          <SaveBtn label={editItem ? '💾 تحديث المؤسسة' : '➕ إضافة المؤسسة'} onClick={saveSchool} loading={saving} />
        </Modal>
      )}

      {/* Modal: تعيين باقة لمدرسة */}
      {assignPlanModal && (
        <Modal title={`📦 تعيين باقة لـ: ${assignPlanModal.name || assignPlanModal.name_ar}`} onClose={() => setAssignPlanModal(null)}>
          <div style={{ background: 'rgba(201,162,39,0.08)', border: `1px solid ${G}33`, borderRadius: 10, padding: '12px 16px', marginBottom: 16 }}>
            <div style={{ fontSize: 12, color: G, fontWeight: 600 }}>⚠️ سيتم إلغاء الاشتراك الحالي وإنشاء اشتراك جديد</div>
          </div>
          <Select label="اختر الباقة *" value={assignPlanForm.plan_id} onChange={(v: string) => setAssignPlanForm(f => ({ ...f, plan_id: v }))}
            options={[{ value: '', label: '-- اختر الباقة --' }, ...plans.map(p => ({ value: p.id, label: `${p.name_ar || p.name} — ${p.price_monthly} ريال/شهر` }))]} />
          <Select label="مدة الاشتراك" value={assignPlanForm.duration_months} onChange={(v: string) => setAssignPlanForm(f => ({ ...f, duration_months: v }))}
            options={[{ value: '1', label: 'شهر واحد' }, { value: '3', label: '3 أشهر' }, { value: '6', label: '6 أشهر' }, { value: '12', label: 'سنة كاملة' }, { value: '24', label: 'سنتان' }]} />
          {assignPlanForm.plan_id && (
            <div style={{ background: 'rgba(16,185,129,0.08)', border: '1px solid rgba(16,185,129,0.2)', borderRadius: 10, padding: '12px 16px', marginBottom: 16 }}>
              {(() => {
                const plan = plans.find(p => p.id == assignPlanForm.plan_id);
                const months = parseInt(assignPlanForm.duration_months);
                const total = plan ? plan.price_monthly * months : 0;
                return <div style={{ fontSize: 13, color: '#10B981', fontWeight: 600 }}>💰 الإجمالي: {total.toLocaleString('ar-SA')} ريال لمدة {months} شهر</div>;
              })()}
            </div>
          )}
          <SaveBtn label="✅ تعيين الباقة" onClick={assignPlan} loading={saving} />
        </Modal>
      )}

      {/* Modal: تعديل صلاحيات مستخدم */}
      {editPermModal && (
        <Modal title={`🔑 تعديل صلاحيات: ${editPermModal.name}`} onClose={() => setEditPermModal(null)}>
          <div style={{ background: 'rgba(255,255,255,0.03)', borderRadius: 10, padding: '12px 16px', marginBottom: 16 }}>
            <div style={{ fontSize: 12, color: 'rgba(255,255,255,0.4)', marginBottom: 4 }}>البريد الإلكتروني</div>
            <div style={{ fontSize: 14, color: 'white' }}>{editPermModal.email}</div>
            {editPermModal.school_name && <>
              <div style={{ fontSize: 12, color: 'rgba(255,255,255,0.4)', marginTop: 8, marginBottom: 4 }}>المدرسة</div>
              <div style={{ fontSize: 14, color: 'white' }}>{editPermModal.school_name}</div>
            </>}
          </div>
          <Select label="الدور" value={editPermForm.role} onChange={(v: string) => setEditPermForm(f => ({ ...f, role: v }))}
            options={ROLES.map(r => ({ value: r.value, label: r.label }))} />
          <Select label="الحالة" value={editPermForm.status} onChange={(v: string) => setEditPermForm(f => ({ ...f, status: v, is_active: v === 'active' }))}
            options={[{ value: 'active', label: 'نشط ✅' }, { value: 'pending', label: 'معلق ⏳' }, { value: 'suspended', label: 'موقوف 🚫' }, { value: 'rejected', label: 'مرفوض ❌' }]} />
          <div style={{ marginBottom: 14 }}>
            <label style={{ display: 'flex', alignItems: 'center', gap: 10, cursor: 'pointer' }}>
              <input type="checkbox" checked={editPermForm.is_active} onChange={e => setEditPermForm(f => ({ ...f, is_active: e.target.checked }))} style={{ width: 18, height: 18, cursor: 'pointer' }} />
              <span style={{ color: 'rgba(255,255,255,0.7)', fontSize: 14 }}>حساب نشط (يمكنه تسجيل الدخول)</span>
            </label>
          </div>
          <SaveBtn label="💾 حفظ الصلاحيات" onClick={savePermission} loading={saving} />
        </Modal>
      )}

      {/* Modal: باقة جديدة/تعديل */}
      {planModal && (
        <Modal title={editItem ? '✏️ تعديل الباقة' : '📦 إضافة باقة جديدة'} onClose={() => { setPlanModal(false); setEditItem(null); }}>
          <Input label="اسم الباقة *" value={pf.name_ar} onChange={(v: string) => setPf(f => ({ ...f, name_ar: v }))} placeholder="مثال: الباقة الاحترافية" />
          <Input label="السعر الشهري (ريال)" value={pf.price_monthly} onChange={(v: string) => setPf(f => ({ ...f, price_monthly: v }))} type="number" placeholder="299" />
          <Input label="السعر السنوي (ريال)" value={pf.price_yearly} onChange={(v: string) => setPf(f => ({ ...f, price_yearly: v }))} type="number" placeholder="2999" />
          <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 12 }}>
            <Input label="الحد الأقصى للطلاب" value={pf.max_students} onChange={(v: string) => setPf(f => ({ ...f, max_students: v }))} type="number" />
            <Input label="الحد الأقصى للمعلمين" value={pf.max_teachers} onChange={(v: string) => setPf(f => ({ ...f, max_teachers: v }))} type="number" />
          </div>
          <div style={{ marginBottom: 14 }}>
            <label style={{ color: 'rgba(255,255,255,0.5)', fontSize: 12, fontWeight: 600, display: 'block', marginBottom: 6 }}>المميزات (كل ميزة في سطر)</label>
            <textarea value={pf.features} onChange={e => setPf(f => ({ ...f, features: e.target.value }))} placeholder="إدارة الطلاب&#10;إدارة المعلمين&#10;الاختبارات الإلكترونية"
              style={{ width: '100%', background: 'rgba(255,255,255,0.05)', border: `1px solid ${BORDER}`, borderRadius: 10, padding: '10px 14px', color: 'white', fontSize: 13, outline: 'none', boxSizing: 'border-box', minHeight: 100, resize: 'vertical' }} />
          </div>
          <div style={{ marginBottom: 14 }}>
            <label style={{ display: 'flex', alignItems: 'center', gap: 10, cursor: 'pointer' }}>
              <input type="checkbox" checked={pf.is_active} onChange={e => setPf(f => ({ ...f, is_active: e.target.checked }))} style={{ width: 18, height: 18 }} />
              <span style={{ color: 'rgba(255,255,255,0.7)', fontSize: 14 }}>باقة نشطة (تظهر للمدارس)</span>
            </label>
          </div>
          <SaveBtn label={editItem ? '💾 تحديث الباقة' : '➕ إضافة الباقة'} onClick={savePlan} loading={saving} />
        </Modal>
      )}

      {/* Modal: إعلان */}
      {adModal && (
        <Modal title={editItem ? '✏️ تعديل الإعلان' : '📢 إعلان جديد'} onClose={() => { setAdModal(false); setEditItem(null); }}>
          <Input label="عنوان الإعلان *" value={af.title} onChange={(v: string) => setAf(f => ({ ...f, title: v }))} placeholder="عنوان الإعلان" />
          <Input label="رابط الصورة" value={af.image_url} onChange={(v: string) => setAf(f => ({ ...f, image_url: v }))} placeholder="https://..." />
          <Input label="رابط الإعلان (عند النقر)" value={af.click_url} onChange={(v: string) => setAf(f => ({ ...f, click_url: v }))} placeholder="https://..." />
          <Select label="موضع الإعلان" value={af.position} onChange={(v: string) => setAf(f => ({ ...f, position: v }))}
            options={[{ value: 'top', label: 'أعلى الصفحة' }, { value: 'sidebar', label: 'الشريط الجانبي' }, { value: 'bottom', label: 'أسفل الصفحة' }, { value: 'popup', label: 'نافذة منبثقة' }]} />
          <Input label="الأولوية (1 = الأعلى)" value={af.priority} onChange={(v: string) => setAf(f => ({ ...f, priority: v }))} type="number" />
          <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 12 }}>
            <Input label="تاريخ البداية" value={af.start_date} onChange={(v: string) => setAf(f => ({ ...f, start_date: v }))} type="date" />
            <Input label="تاريخ الانتهاء" value={af.end_date} onChange={(v: string) => setAf(f => ({ ...f, end_date: v }))} type="date" />
          </div>
          <SaveBtn label={editItem ? '💾 تحديث الإعلان' : '📢 نشر الإعلان'} onClick={saveAd} loading={saving} />
        </Modal>
      )}

      {/* Modal: إشعار */}
      {notifModal && (
        <Modal title="🔔 إرسال إشعار جماعي" onClose={() => setNotifModal(false)}>
          <Input label="عنوان الإشعار *" value={notifForm.title} onChange={(v: string) => setNotifForm(f => ({ ...f, title: v }))} placeholder="مثال: تحديث مهم" />
          <div style={{ marginBottom: 14 }}>
            <label style={{ color: 'rgba(255,255,255,0.5)', fontSize: 12, fontWeight: 600, display: 'block', marginBottom: 6 }}>محتوى الإشعار *</label>
            <textarea value={notifForm.body} onChange={e => setNotifForm(f => ({ ...f, body: e.target.value }))} placeholder="اكتب محتوى الإشعار..."
              style={{ width: '100%', background: 'rgba(255,255,255,0.05)', border: `1px solid ${BORDER}`, borderRadius: 10, padding: '10px 14px', color: 'white', fontSize: 13, outline: 'none', boxSizing: 'border-box', minHeight: 80, resize: 'vertical' }} />
          </div>
          <Select label="الجمهور" value={notifForm.target} onChange={(v: string) => setNotifForm(f => ({ ...f, target: v }))}
            options={[{ value: 'all', label: 'الجميع' }, { value: 'owners', label: 'ملاك المدارس' }, { value: 'teachers', label: 'المعلمون' }, { value: 'students', label: 'الطلاب' }]} />
          <SaveBtn label="📤 إرسال الإشعار" onClick={sendNotification} loading={saving} />
        </Modal>
      )}

    </div>
  );
}
