'use client';
export const dynamic = 'force-dynamic';

/* MATIN CMS — إدارة محتوى الموقع الرئيسي
   يتيح لمالك المنصة التحكم الكامل في:
   - الأخبار والإعلانات
   - المميزات والخدمات
   - الشركاء
   - الباقات والأسعار
   الهوية البصرية: Dark Premium | Gold #C9A84C | Cairo Font */

import { useState, useEffect } from 'react';
import { AlertCircle, CheckCircle, CreditCard, Eye, Globe, Handshake, LayoutDashboard, Loader2, Newspaper, Pencil, Plus, Save, Trash2, X, Zap } from "lucide-react";
import { getHeaders } from '@/lib/api';

const GOLD = '#C9A84C';
const BG = '#0B0B16';
const CARD = 'rgba(255,255,255,0.04)';
const BORDER = 'rgba(255,255,255,0.08)';


type Tab = 'news' | 'features' | 'partners' | 'plans';

const TABS: { id: Tab; label: string; icon: React.ReactNode; color: string }[] = [
  { id: 'news', label: 'الأخبار', icon: <Newspaper size={18} />, color: '#D4A843' },
  { id: 'features', label: 'المميزات', icon: <Zap size={18} />, color: '#22C55E' },
  { id: 'partners', label: 'الشركاء', icon: <Handshake size={18} />, color: '#60A5FA' },
  { id: 'plans', label: 'الباقات والأسعار', icon: <CreditCard size={18} />, color: '#A78BFA' },
];

// ─── Toast ───────────────────────────────────────────────────────────────────
function Toast({ msg, type, onClose }: { msg: string; type: 'success' | 'error'; onClose: () => void }) {
  useEffect(() => { const t = setTimeout(onClose, 3500); return () => clearTimeout(t); }, [onClose]);
  return (
    <div style={{
      position: 'fixed', bottom: 24, left: '50%', transform: 'translateX(-50%)',
      background: type === 'success' ? 'rgba(34,197,94,0.15)' : 'rgba(239,68,68,0.15)',
      border: `1px solid ${type === 'success' ? '#22C55E' : '#EF4444'}`,
      color: type === 'success' ? '#22C55E' : '#EF4444',
      padding: '12px 24px', borderRadius: 12, display: 'flex', alignItems: 'center', gap: 8,
      zIndex: 9999, fontSize: 14, fontWeight: 600, backdropFilter: 'blur(12px)'
    }}>
      {type === 'success' ? <CheckCircle size={16} /> : <AlertCircle size={16} />}
      {msg}
      <button onClick={onClose} style={{ marginRight: 8, opacity: 0.7 }}><X size={14} /></button>
    </div>
  );
}

// ─── Modal ───────────────────────────────────────────────────────────────────
function Modal({ title, onClose, children }: { title: string; onClose: () => void; children: React.ReactNode }) {
  return (
    <div style={{
      position: 'fixed', inset: 0, background: 'rgba(0,0,0,0.7)',
      display: 'flex', alignItems: 'center', justifyContent: 'center',
      zIndex: 1000, padding: 16, backdropFilter: 'blur(4px)'
    }}>
      <div style={{
        background: '#12121F', border: `1px solid ${BORDER}`,
        borderRadius: 16, padding: 24, width: '100%', maxWidth: 520,
        maxHeight: '90vh', overflowY: 'auto'
      }}>
        <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: 20 }}>
          <h3 style={{ color: '#fff', fontWeight: 700, fontSize: 16 }}>{title}</h3>
          <button onClick={onClose} style={{ color: '#666', cursor: 'pointer' }}><X size={18} /></button>
        </div>
        {children}
      </div>
    </div>
  );
}

function Field({ label, children }: { label: string; children: React.ReactNode }) {
  return (
    <div style={{ marginBottom: 14 }}>
      <label style={{ display: 'block', color: '#aaa', fontSize: 12, marginBottom: 6 }}>{label}</label>
      {children}
    </div>
  );
}

const inputStyle: React.CSSProperties = {
  width: '100%', background: 'rgba(255,255,255,0.06)', border: `1px solid ${BORDER}`,
  borderRadius: 8, padding: '10px 12px', color: '#fff', fontSize: 14, outline: 'none',
  boxSizing: 'border-box'
};

// ─── NEWS TAB ─────────────────────────────────────────────────────────────────
function NewsTab() {
  const [items, setItems] = useState<any[]>([]);
  const [loading, setLoading] = useState(true);
  const [showModal, setShowModal] = useState(false);
  const [editItem, setEditItem] = useState<any>(null);
  const [saving, setSaving] = useState(false);
  const [toast, setToast] = useState<{ msg: string; type: 'success' | 'error' } | null>(null);
  const [form, setForm] = useState({ title: '', description: '', category: '', image_url: '' });

  const load = async () => {
    setLoading(true);
    try {
      const res = await fetch('/api/news', { headers: getHeaders() });
      const data = await res.json();
      setItems(Array.isArray(data) ? data : (data.news || []));
    } catch { setItems([]); } finally { setLoading(false); }
  };

  useEffect(() => { load(); }, []);

  const openAdd = () => { setEditItem(null); setForm({ title: '', description: '', category: '', image_url: '' }); setShowModal(true); };
  const openEdit = (item: any) => { setEditItem(item); setForm({ title: item.title || '', description: item.description || '', category: item.category || '', image_url: item.image_url || '' }); setShowModal(true); };

  const handleSave = async () => {
    if (!form.title) { setToast({ msg: 'أدخل عنوان الخبر', type: 'error' }); return; }
    setSaving(true);
    try {
      const method = editItem ? 'PUT' : 'POST';
      const url = editItem ? `/api/news?id=${editItem.id}` : '/api/news';
      const res = await fetch(url, { method, headers: getHeaders(), body: JSON.stringify(form) });
      if (!res.ok) throw new Error('فشل الحفظ');
      setToast({ msg: editItem ? 'تم تحديث الخبر' : 'تم إضافة الخبر', type: 'success' });
      setShowModal(false); load();
    } catch (e: any) { setToast({ msg: e.message, type: 'error' }); } finally { setSaving(false); }
  };

  const handleDelete = async (id: number) => {
    if (!confirm('هل أنت متأكد من حذف هذا الخبر؟')) return;
    try {
      await fetch(`/api/news?id=${id}`, { method: 'DELETE', headers: getHeaders() });
      setToast({ msg: 'تم حذف الخبر', type: 'success' }); load();
    } catch { setToast({ msg: 'فشل الحذف', type: 'error' }); }
  };

  return (
    <div>
      {toast && <Toast msg={toast.msg} type={toast.type} onClose={() => setToast(null)} />}
      <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: 20 }}>
        <p style={{ color: '#888', fontSize: 13 }}>تظهر هذه الأخبار في صفحة <strong style={{ color: '#D4A843' }}>/news</strong> على الموقع</p>
        <button onClick={openAdd} style={{
          background: `linear-gradient(135deg, ${GOLD}, #a8832a)`,
          color: '#000', border: 'none', borderRadius: 10, padding: '10px 18px',
          fontWeight: 700, cursor: 'pointer', display: 'flex', alignItems: 'center', gap: 6, fontSize: 13
        }}>
          <Plus size={16} /> إضافة خبر
        </button>
      </div>

      {loading ? (
        <div style={{ textAlign: 'center', padding: 40 }}>
          <Loader2 size={28} style={{ color: GOLD, animation: 'spin 1s linear infinite' }} />
        </div>
      ) : (
        <div style={{ display: 'grid', gap: 12 }}>
          {items.length === 0 && <p style={{ color: '#555', textAlign: 'center', padding: 40 }}>لا توجد أخبار بعد</p>}
          {items.map((item) => (
            <div key={item.id} style={{ background: CARD, border: `1px solid ${BORDER}`, borderRadius: 12, padding: '14px 18px', display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
              <div>
                <div style={{ color: '#fff', fontWeight: 600, fontSize: 14, marginBottom: 4 }}>{item.title}</div>
                <div style={{ color: '#666', fontSize: 12 }}>{item.category} · {item.description?.slice(0, 60)}...</div>
              </div>
              <div style={{ display: 'flex', gap: 8 }}>
                <button onClick={() => openEdit(item)} style={{ background: 'rgba(212,168,67,0.1)', color: '#D4A843', border: 'none', borderRadius: 8, padding: '6px 10px', cursor: 'pointer' }}>
                  <Pencil size={14} />
                </button>
                <button onClick={() => handleDelete(item.id)} style={{ background: 'rgba(239,68,68,0.1)', color: '#EF4444', border: 'none', borderRadius: 8, padding: '6px 10px', cursor: 'pointer' }}>
                  <Trash2 size={14} />
                </button>
              </div>
            </div>
          ))}
        </div>
      )}

      {showModal && (
        <Modal title={editItem ? 'تعديل الخبر' : 'إضافة خبر جديد'} onClose={() => setShowModal(false)}>
          <Field label="عنوان الخبر *">
            <input style={inputStyle} value={form.title} onChange={e => setForm({ ...form, title: e.target.value })} placeholder="مثال: إطلاق الإصدار 3.0 من منصة متين" />
          </Field>
          <Field label="الوصف">
            <textarea style={{ ...inputStyle, minHeight: 80, resize: 'vertical' }} value={form.description} onChange={e => setForm({ ...form, description: e.target.value })} placeholder="وصف مختصر للخبر..." />
          </Field>
          <Field label="التصنيف">
            <input style={inputStyle} value={form.category} onChange={e => setForm({ ...form, category: e.target.value })} placeholder="مثال: إطلاق، شراكة، تكامل، تقنية" />
          </Field>
          <Field label="رابط الصورة (اختياري)">
            <input style={inputStyle} value={form.image_url} onChange={e => setForm({ ...form, image_url: e.target.value })} placeholder="https://..." />
          </Field>
          <button onClick={handleSave} disabled={saving} style={{
            width: '100%', background: `linear-gradient(135deg, ${GOLD}, #a8832a)`,
            color: '#000', border: 'none', borderRadius: 10, padding: '12px',
            fontWeight: 700, cursor: saving ? 'not-allowed' : 'pointer', display: 'flex', alignItems: 'center', justifyContent: 'center', gap: 8, marginTop: 8
          }}>
            {saving ? <Loader2 size={16} style={{ animation: 'spin 1s linear infinite' }} /> : <Save size={16} />}
            {saving ? 'جاري الحفظ...' : 'حفظ'}
          </button>
        </Modal>
      )}
    </div>
  );
}

// ─── FEATURES TAB ─────────────────────────────────────────────────────────────
function FeaturesTab() {
  const [items, setItems] = useState<any[]>([]);
  const [loading, setLoading] = useState(true);
  const [showModal, setShowModal] = useState(false);
  const [editItem, setEditItem] = useState<any>(null);
  const [saving, setSaving] = useState(false);
  const [toast, setToast] = useState<{ msg: string; type: 'success' | 'error' } | null>(null);
  const [form, setForm] = useState({ title: '', description: '', category: '', icon_name: '', color: '#D4A843', sort_order: 0 });

  const load = async () => {
    setLoading(true);
    try {
      const res = await fetch('/api/features', { headers: getHeaders() });
      const data = await res.json();
      setItems(Array.isArray(data) ? data : (data.features || []));
    } catch { setItems([]); } finally { setLoading(false); }
  };

  useEffect(() => { load(); }, []);

  const openAdd = () => { setEditItem(null); setForm({ title: '', description: '', category: '', icon_name: '', color: '#D4A843', sort_order: 0 }); setShowModal(true); };
  const openEdit = (item: any) => { setEditItem(item); setForm({ title: item.title || '', description: item.description || '', category: item.category || '', icon_name: item.icon_name || '', color: item.color || '#D4A843', sort_order: item.sort_order || 0 }); setShowModal(true); };

  const handleSave = async () => {
    if (!form.title) { setToast({ msg: 'أدخل اسم الميزة', type: 'error' }); return; }
    setSaving(true);
    try {
      const method = editItem ? 'PUT' : 'POST';
      const url = editItem ? `/api/features?id=${editItem.id}` : '/api/features';
      const res = await fetch(url, { method, headers: getHeaders(), body: JSON.stringify(form) });
      if (!res.ok) throw new Error('فشل الحفظ');
      setToast({ msg: editItem ? 'تم تحديث الميزة' : 'تم إضافة الميزة', type: 'success' });
      setShowModal(false); load();
    } catch (e: any) { setToast({ msg: e.message, type: 'error' }); } finally { setSaving(false); }
  };

  const handleDelete = async (id: number) => {
    if (!confirm('هل أنت متأكد من حذف هذه الميزة؟')) return;
    try {
      await fetch(`/api/features?id=${id}`, { method: 'DELETE', headers: getHeaders() });
      setToast({ msg: 'تم حذف الميزة', type: 'success' }); load();
    } catch { setToast({ msg: 'فشل الحذف', type: 'error' }); }
  };

  return (
    <div>
      {toast && <Toast msg={toast.msg} type={toast.type} onClose={() => setToast(null)} />}
      <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: 20 }}>
        <p style={{ color: '#888', fontSize: 13 }}>تظهر هذه المميزات في صفحة <strong style={{ color: '#22C55E' }}>/features</strong> على الموقع</p>
        <button onClick={openAdd} style={{
          background: 'linear-gradient(135deg, #22C55E, #16a34a)',
          color: '#000', border: 'none', borderRadius: 10, padding: '10px 18px',
          fontWeight: 700, cursor: 'pointer', display: 'flex', alignItems: 'center', gap: 6, fontSize: 13
        }}>
          <Plus size={16} /> إضافة ميزة
        </button>
      </div>

      {loading ? (
        <div style={{ textAlign: 'center', padding: 40 }}>
          <Loader2 size={28} style={{ color: '#22C55E', animation: 'spin 1s linear infinite' }} />
        </div>
      ) : (
        <div style={{ display: 'grid', gap: 12 }}>
          {items.length === 0 && <p style={{ color: '#555', textAlign: 'center', padding: 40 }}>لا توجد مميزات بعد</p>}
          {items.map((item) => (
            <div key={item.id} style={{ background: CARD, border: `1px solid ${BORDER}`, borderRadius: 12, padding: '14px 18px', display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
              <div style={{ display: 'flex', alignItems: 'center', gap: 12 }}>
                <div style={{ width: 36, height: 36, borderRadius: 8, background: `${item.color || '#D4A843'}20`, display: 'flex', alignItems: 'center', justifyContent: 'center' }}>
                  <Zap size={16} style={{ color: item.color || '#D4A843' }} />
                </div>
                <div>
                  <div style={{ color: '#fff', fontWeight: 600, fontSize: 14 }}>{item.title}</div>
                  <div style={{ color: '#666', fontSize: 12 }}>{item.category}</div>
                </div>
              </div>
              <div style={{ display: 'flex', gap: 8 }}>
                <button onClick={() => openEdit(item)} style={{ background: 'rgba(212,168,67,0.1)', color: '#D4A843', border: 'none', borderRadius: 8, padding: '6px 10px', cursor: 'pointer' }}>
                  <Pencil size={14} />
                </button>
                <button onClick={() => handleDelete(item.id)} style={{ background: 'rgba(239,68,68,0.1)', color: '#EF4444', border: 'none', borderRadius: 8, padding: '6px 10px', cursor: 'pointer' }}>
                  <Trash2 size={14} />
                </button>
              </div>
            </div>
          ))}
        </div>
      )}

      {showModal && (
        <Modal title={editItem ? 'تعديل الميزة' : 'إضافة ميزة جديدة'} onClose={() => setShowModal(false)}>
          <Field label="اسم الميزة *">
            <input style={inputStyle} value={form.title} onChange={e => setForm({ ...form, title: e.target.value })} placeholder="مثال: الإدارة الأكاديمية" />
          </Field>
          <Field label="الوصف">
            <textarea style={{ ...inputStyle, minHeight: 70, resize: 'vertical' }} value={form.description} onChange={e => setForm({ ...form, description: e.target.value })} placeholder="وصف مختصر للميزة..." />
          </Field>
          <Field label="التصنيف">
            <input style={inputStyle} value={form.category} onChange={e => setForm({ ...form, category: e.target.value })} placeholder="مثال: أكاديمي، أمان، تحليل" />
          </Field>
          <Field label="اسم الأيقونة (Lucide)">
            <input style={inputStyle} value={form.icon_name} onChange={e => setForm({ ...form, icon_name: e.target.value })} placeholder="مثال: GraduationCap, Shield, BarChart3" />
          </Field>
          <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 12 }}>
            <Field label="اللون">
              <div style={{ display: 'flex', gap: 8, alignItems: 'center' }}>
                <input type="color" value={form.color} onChange={e => setForm({ ...form, color: e.target.value })} style={{ width: 40, height: 36, borderRadius: 6, border: 'none', cursor: 'pointer', background: 'transparent' }} />
                <input style={{ ...inputStyle, flex: 1 }} value={form.color} onChange={e => setForm({ ...form, color: e.target.value })} placeholder="#D4A843" />
              </div>
            </Field>
            <Field label="الترتيب">
              <input type="number" style={inputStyle} value={form.sort_order} onChange={e => setForm({ ...form, sort_order: Number(e.target.value) })} />
            </Field>
          </div>
          <button onClick={handleSave} disabled={saving} style={{
            width: '100%', background: 'linear-gradient(135deg, #22C55E, #16a34a)',
            color: '#000', border: 'none', borderRadius: 10, padding: '12px',
            fontWeight: 700, cursor: saving ? 'not-allowed' : 'pointer', display: 'flex', alignItems: 'center', justifyContent: 'center', gap: 8, marginTop: 8
          }}>
            {saving ? <Loader2 size={16} style={{ animation: 'spin 1s linear infinite' }} /> : <Save size={16} />}
            {saving ? 'جاري الحفظ...' : 'حفظ'}
          </button>
        </Modal>
      )}
    </div>
  );
}

// ─── PARTNERS TAB ─────────────────────────────────────────────────────────────
function PartnersTab() {
  const [items, setItems] = useState<any[]>([]);
  const [loading, setLoading] = useState(true);
  const [showModal, setShowModal] = useState(false);
  const [editItem, setEditItem] = useState<any>(null);
  const [saving, setSaving] = useState(false);
  const [toast, setToast] = useState<{ msg: string; type: 'success' | 'error' } | null>(null);
  const [form, setForm] = useState({ name: '', website_url: '', logo_url: '', category: '' });

  const load = async () => {
    setLoading(true);
    try {
      const res = await fetch('/api/partners', { headers: getHeaders() });
      const data = await res.json();
      setItems(Array.isArray(data) ? data : (data.partners || []));
    } catch { setItems([]); } finally { setLoading(false); }
  };

  useEffect(() => { load(); }, []);

  const openAdd = () => { setEditItem(null); setForm({ name: '', website_url: '', logo_url: '', category: '' }); setShowModal(true); };
  const openEdit = (item: any) => { setEditItem(item); setForm({ name: item.name || '', website_url: item.website_url || item.website || '', logo_url: item.logo_url || '', category: item.category || item.type || '' }); setShowModal(true); };

  const handleSave = async () => {
    if (!form.name) { setToast({ msg: 'أدخل اسم الشريك', type: 'error' }); return; }
    setSaving(true);
    try {
      const method = editItem ? 'PUT' : 'POST';
      const url = editItem ? `/api/partners?id=${editItem.id}` : '/api/partners';
      const res = await fetch(url, { method, headers: getHeaders(), body: JSON.stringify(form) });
      if (!res.ok) throw new Error('فشل الحفظ');
      setToast({ msg: editItem ? 'تم تحديث الشريك' : 'تم إضافة الشريك', type: 'success' });
      setShowModal(false); load();
    } catch (e: any) { setToast({ msg: e.message, type: 'error' }); } finally { setSaving(false); }
  };

  const handleDelete = async (id: number) => {
    if (!confirm('هل أنت متأكد من حذف هذا الشريك؟')) return;
    try {
      await fetch(`/api/partners?id=${id}`, { method: 'DELETE', headers: getHeaders() });
      setToast({ msg: 'تم حذف الشريك', type: 'success' }); load();
    } catch { setToast({ msg: 'فشل الحذف', type: 'error' }); }
  };

  return (
    <div>
      {toast && <Toast msg={toast.msg} type={toast.type} onClose={() => setToast(null)} />}
      <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: 20 }}>
        <p style={{ color: '#888', fontSize: 13 }}>تظهر هؤلاء الشركاء على الموقع الرئيسي</p>
        <button onClick={openAdd} style={{
          background: 'linear-gradient(135deg, #60A5FA, #2563eb)',
          color: '#fff', border: 'none', borderRadius: 10, padding: '10px 18px',
          fontWeight: 700, cursor: 'pointer', display: 'flex', alignItems: 'center', gap: 6, fontSize: 13
        }}>
          <Plus size={16} /> إضافة شريك
        </button>
      </div>

      {loading ? (
        <div style={{ textAlign: 'center', padding: 40 }}>
          <Loader2 size={28} style={{ color: '#60A5FA', animation: 'spin 1s linear infinite' }} />
        </div>
      ) : (
        <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fill, minmax(240px, 1fr))', gap: 12 }}>
          {items.length === 0 && <p style={{ color: '#555', textAlign: 'center', padding: 40, gridColumn: '1/-1' }}>لا يوجد شركاء بعد</p>}
          {items.map((item) => (
            <div key={item.id} style={{ background: CARD, border: `1px solid ${BORDER}`, borderRadius: 12, padding: '14px 16px' }}>
              <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'flex-start' }}>
                <div>
                  <div style={{ color: '#fff', fontWeight: 600, fontSize: 14 }}>{item.name}</div>
                  <div style={{ color: '#666', fontSize: 12, marginTop: 2 }}>{item.category || item.type}</div>
                  {(item.website_url || item.website) && (
                    <a href={item.website_url || item.website} target="_blank" rel="noreferrer" style={{ color: '#60A5FA', fontSize: 11, display: 'flex', alignItems: 'center', gap: 4, marginTop: 4 }}>
                      <Globe size={10} /> الموقع
                    </a>
                  )}
                </div>
                <div style={{ display: 'flex', flexDirection: 'column', gap: 6 }}>
                  <button onClick={() => openEdit(item)} style={{ background: 'rgba(212,168,67,0.1)', color: '#D4A843', border: 'none', borderRadius: 6, padding: '5px 8px', cursor: 'pointer' }}>
                    <Pencil size={12} />
                  </button>
                  <button onClick={() => handleDelete(item.id)} style={{ background: 'rgba(239,68,68,0.1)', color: '#EF4444', border: 'none', borderRadius: 6, padding: '5px 8px', cursor: 'pointer' }}>
                    <Trash2 size={12} />
                  </button>
                </div>
              </div>
            </div>
          ))}
        </div>
      )}

      {showModal && (
        <Modal title={editItem ? 'تعديل الشريك' : 'إضافة شريك جديد'} onClose={() => setShowModal(false)}>
          <Field label="اسم الشريك *">
            <input style={inputStyle} value={form.name} onChange={e => setForm({ ...form, name: e.target.value })} placeholder="مثال: STC Pay" />
          </Field>
          <Field label="التصنيف">
            <input style={inputStyle} value={form.category} onChange={e => setForm({ ...form, category: e.target.value })} placeholder="مثال: دفع إلكتروني، حكومي، تقني" />
          </Field>
          <Field label="رابط الموقع">
            <input style={inputStyle} value={form.website_url} onChange={e => setForm({ ...form, website_url: e.target.value })} placeholder="https://..." />
          </Field>
          <Field label="رابط الشعار">
            <input style={inputStyle} value={form.logo_url} onChange={e => setForm({ ...form, logo_url: e.target.value })} placeholder="https://..." />
          </Field>
          <button onClick={handleSave} disabled={saving} style={{
            width: '100%', background: 'linear-gradient(135deg, #60A5FA, #2563eb)',
            color: '#fff', border: 'none', borderRadius: 10, padding: '12px',
            fontWeight: 700, cursor: saving ? 'not-allowed' : 'pointer', display: 'flex', alignItems: 'center', justifyContent: 'center', gap: 8, marginTop: 8
          }}>
            {saving ? <Loader2 size={16} style={{ animation: 'spin 1s linear infinite' }} /> : <Save size={16} />}
            {saving ? 'جاري الحفظ...' : 'حفظ'}
          </button>
        </Modal>
      )}
    </div>
  );
}

// ─── PLANS TAB ────────────────────────────────────────────────────────────────
function PlansTab() {
  const [items, setItems] = useState<any[]>([]);
  const [loading, setLoading] = useState(true);
  const [showModal, setShowModal] = useState(false);
  const [editItem, setEditItem] = useState<any>(null);
  const [saving, setSaving] = useState(false);
  const [toast, setToast] = useState<{ msg: string; type: 'success' | 'error' } | null>(null);
  const [form, setForm] = useState({ name: '', name_ar: '', price_monthly: '', price_yearly: '', description: '', features: '', max_students: '', max_teachers: '', is_popular: false });

  const load = async () => {
    setLoading(true);
    try {
      const res = await fetch('/api/plans', { headers: getHeaders() });
      const data = await res.json();
      setItems(Array.isArray(data) ? data : (data.plans || []));
    } catch { setItems([]); } finally { setLoading(false); }
  };

  useEffect(() => { load(); }, []);

  const openAdd = () => {
    setEditItem(null);
    setForm({ name: '', name_ar: '', price_monthly: '', price_yearly: '', description: '', features: '', max_students: '', max_teachers: '', is_popular: false });
    setShowModal(true);
  };
  const openEdit = (item: any) => {
    setEditItem(item);
    const feats = Array.isArray(item.features) ? item.features.join('\n') : (item.features || '');
    setForm({
      name: item.name || '', name_ar: item.name_ar || '',
      price_monthly: String(item.price_monthly || item.price || ''),
      price_yearly: String(item.price_yearly || ''),
      description: item.description || '', features: feats,
      max_students: String(item.max_students || ''), max_teachers: String(item.max_teachers || ''),
      is_popular: item.is_popular || false
    });
    setShowModal(true);
  };

  const handleSave = async () => {
    if (!form.name) { setToast({ msg: 'أدخل اسم الباقة', type: 'error' }); return; }
    setSaving(true);
    try {
      const payload = {
        ...form,
        features: form.features.split('\n').filter(Boolean),
        price_monthly: Number(form.price_monthly) || 0,
        price_yearly: Number(form.price_yearly) || 0,
        max_students: Number(form.max_students) || null,
        max_teachers: Number(form.max_teachers) || null,
      };
      const method = editItem ? 'PUT' : 'POST';
      const url = editItem ? `/api/plans?id=${editItem.id}` : '/api/plans';
      const res = await fetch(url, { method, headers: getHeaders(), body: JSON.stringify(payload) });
      if (!res.ok) throw new Error('فشل الحفظ');
      setToast({ msg: editItem ? 'تم تحديث الباقة' : 'تم إضافة الباقة', type: 'success' });
      setShowModal(false); load();
    } catch (e: any) { setToast({ msg: e.message, type: 'error' }); } finally { setSaving(false); }
  };

  const handleDelete = async (id: number) => {
    if (!confirm('هل أنت متأكد من حذف هذه الباقة؟')) return;
    try {
      await fetch(`/api/plans?id=${id}`, { method: 'DELETE', headers: getHeaders() });
      setToast({ msg: 'تم حذف الباقة', type: 'success' }); load();
    } catch { setToast({ msg: 'فشل الحذف', type: 'error' }); }
  };

  return (
    <div>
      {toast && <Toast msg={toast.msg} type={toast.type} onClose={() => setToast(null)} />}
      <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: 20 }}>
        <p style={{ color: '#888', fontSize: 13 }}>تظهر هذه الباقات في صفحة <strong style={{ color: '#A78BFA' }}>/pricing</strong> على الموقع</p>
        <button onClick={openAdd} style={{
          background: 'linear-gradient(135deg, #A78BFA, #7c3aed)',
          color: '#fff', border: 'none', borderRadius: 10, padding: '10px 18px',
          fontWeight: 700, cursor: 'pointer', display: 'flex', alignItems: 'center', gap: 6, fontSize: 13
        }}>
          <Plus size={16} /> إضافة باقة
        </button>
      </div>

      {loading ? (
        <div style={{ textAlign: 'center', padding: 40 }}>
          <Loader2 size={28} style={{ color: '#A78BFA', animation: 'spin 1s linear infinite' }} />
        </div>
      ) : (
        <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fill, minmax(260px, 1fr))', gap: 12 }}>
          {items.length === 0 && <p style={{ color: '#555', textAlign: 'center', padding: 40, gridColumn: '1/-1' }}>لا توجد باقات بعد</p>}
          {items.map((item) => (
            <div key={item.id} style={{
              background: CARD, border: `1px solid ${item.is_popular ? '#A78BFA' : BORDER}`,
              borderRadius: 12, padding: '16px'
            }}>
              <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'flex-start', marginBottom: 8 }}>
                <div>
                  <div style={{ color: '#fff', fontWeight: 700, fontSize: 15 }}>{item.name_ar || item.name}</div>
                  {item.is_popular && <span style={{ background: 'rgba(167,139,250,0.15)', color: '#A78BFA', fontSize: 10, padding: '2px 8px', borderRadius: 20, fontWeight: 600 }}>الأكثر شيوعاً</span>}
                </div>
                <div style={{ textAlign: 'left' }}>
                  <div style={{ color: GOLD, fontWeight: 700, fontSize: 18 }}>{item.price_monthly || item.price} ر.س</div>
                  <div style={{ color: '#555', fontSize: 11 }}>/ شهرياً</div>
                </div>
              </div>
              <div style={{ color: '#666', fontSize: 12, marginBottom: 12 }}>{item.description}</div>
              <div style={{ display: 'flex', gap: 8 }}>
                <button onClick={() => openEdit(item)} style={{ flex: 1, background: 'rgba(212,168,67,0.1)', color: '#D4A843', border: 'none', borderRadius: 8, padding: '7px', cursor: 'pointer', display: 'flex', alignItems: 'center', justifyContent: 'center', gap: 4, fontSize: 12 }}>
                  <Pencil size={13} /> تعديل
                </button>
                <button onClick={() => handleDelete(item.id)} style={{ background: 'rgba(239,68,68,0.1)', color: '#EF4444', border: 'none', borderRadius: 8, padding: '7px 10px', cursor: 'pointer' }}>
                  <Trash2 size={13} />
                </button>
              </div>
            </div>
          ))}
        </div>
      )}

      {showModal && (
        <Modal title={editItem ? 'تعديل الباقة' : 'إضافة باقة جديدة'} onClose={() => setShowModal(false)}>
          <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 12 }}>
            <Field label="الاسم (إنجليزي) *">
              <input style={inputStyle} value={form.name} onChange={e => setForm({ ...form, name: e.target.value })} placeholder="basic" />
            </Field>
            <Field label="الاسم (عربي)">
              <input style={inputStyle} value={form.name_ar} onChange={e => setForm({ ...form, name_ar: e.target.value })} placeholder="الأساسية" />
            </Field>
            <Field label="السعر الشهري (ر.س)">
              <input type="number" style={inputStyle} value={form.price_monthly} onChange={e => setForm({ ...form, price_monthly: e.target.value })} placeholder="299" />
            </Field>
            <Field label="السعر السنوي (ر.س)">
              <input type="number" style={inputStyle} value={form.price_yearly} onChange={e => setForm({ ...form, price_yearly: e.target.value })} placeholder="2990" />
            </Field>
            <Field label="حد الطلاب">
              <input type="number" style={inputStyle} value={form.max_students} onChange={e => setForm({ ...form, max_students: e.target.value })} placeholder="500" />
            </Field>
            <Field label="حد المعلمين">
              <input type="number" style={inputStyle} value={form.max_teachers} onChange={e => setForm({ ...form, max_teachers: e.target.value })} placeholder="50" />
            </Field>
          </div>
          <Field label="الوصف">
            <input style={inputStyle} value={form.description} onChange={e => setForm({ ...form, description: e.target.value })} placeholder="وصف مختصر للباقة..." />
          </Field>
          <Field label="المميزات (سطر لكل ميزة)">
            <textarea style={{ ...inputStyle, minHeight: 100, resize: 'vertical' }} value={form.features} onChange={e => setForm({ ...form, features: e.target.value })} placeholder={"إدارة الطلاب\nالتقارير الأكاديمية\nالإشعارات الفورية"} />
          </Field>
          <div style={{ display: 'flex', alignItems: 'center', gap: 8, marginBottom: 14 }}>
            <input type="checkbox" id="popular" checked={form.is_popular} onChange={e => setForm({ ...form, is_popular: e.target.checked })} style={{ width: 16, height: 16, cursor: 'pointer' }} />
            <label htmlFor="popular" style={{ color: '#aaa', fontSize: 13, cursor: 'pointer' }}>الأكثر شيوعاً (يظهر بإطار مميز)</label>
          </div>
          <button onClick={handleSave} disabled={saving} style={{
            width: '100%', background: 'linear-gradient(135deg, #A78BFA, #7c3aed)',
            color: '#fff', border: 'none', borderRadius: 10, padding: '12px',
            fontWeight: 700, cursor: saving ? 'not-allowed' : 'pointer', display: 'flex', alignItems: 'center', justifyContent: 'center', gap: 8
          }}>
            {saving ? <Loader2 size={16} style={{ animation: 'spin 1s linear infinite' }} /> : <Save size={16} />}
            {saving ? 'جاري الحفظ...' : 'حفظ الباقة'}
          </button>
        </Modal>
      )}
    </div>
  );
}

// ─── MAIN PAGE ────────────────────────────────────────────────────────────────
export default function WebsiteContentPage() {
  const [activeTab, setActiveTab] = useState<Tab>('news');

  return (
    <div style={{ minHeight: '100vh', background: BG, color: '#fff', fontFamily: 'Cairo, sans-serif', padding: '24px' }}>

      {/* Header */}
      <div style={{ display: 'flex', alignItems: 'center', gap: 16, marginBottom: 28 }}>
        <div style={{ width: 48, height: 48, borderRadius: 14, background: `${GOLD}15`, display: 'flex', alignItems: 'center', justifyContent: 'center' }}>
          <Globe size={24} style={{ color: GOLD }} />
        </div>
        <div>
          <h1 style={{ color: '#fff', fontSize: 22, fontWeight: 800, margin: 0 }}>إدارة محتوى الموقع</h1>
          <p style={{ color: '#666', fontSize: 13, margin: 0 }}>تحكم في محتوى الموقع الرئيسي بدون لمس الكود</p>
        </div>
        <a
          href="/login"
          target="_blank"
          rel="noreferrer"
          style={{
            marginRight: 'auto', background: 'rgba(255,255,255,0.06)', border: `1px solid ${BORDER}`,
            color: '#aaa', borderRadius: 10, padding: '8px 14px', fontSize: 12,
            display: 'flex', alignItems: 'center', gap: 6, textDecoration: 'none'
          }}
        >
          <Eye size={14} /> معاينة الموقع
        </a>
      </div>

      {/* Tabs */}
      <div style={{ display: 'flex', gap: 8, marginBottom: 24, flexWrap: 'wrap' }}>
        {TABS.map(tab => (
          <button
            key={tab.id}
            onClick={() => setActiveTab(tab.id)}
            style={{
              background: activeTab === tab.id ? `${tab.color}15` : 'rgba(255,255,255,0.04)',
              border: `1px solid ${activeTab === tab.id ? tab.color : BORDER}`,
              color: activeTab === tab.id ? tab.color : '#888',
              borderRadius: 10, padding: '10px 18px', cursor: 'pointer',
              display: 'flex', alignItems: 'center', gap: 8, fontSize: 13, fontWeight: 600,
              transition: 'all 0.2s'
            }}
          >
            {tab.icon}
            {tab.label}
          </button>
        ))}
      </div>

      {/* Content */}
      <div style={{ background: CARD, border: `1px solid ${BORDER}`, borderRadius: 16, padding: 24 }}>
        {activeTab === 'news' && <NewsTab />}
        {activeTab === 'features' && <FeaturesTab />}
        {activeTab === 'partners' && <PartnersTab />}
        {activeTab === 'plans' && <PlansTab />}
      </div>

      <style>{`@keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }`}</style>
    </div>
  );
}
