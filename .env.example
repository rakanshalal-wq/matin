# ===================================================
# متين — ملف متغيرات البيئة النموذجي
# انسخ هذا الملف إلى .env.local وعدّل القيم
# ===================================================

# --- قاعدة البيانات (إلزامي) ---
# يجب أن يبدأ بـ postgresql:// أو postgres://
DATABASE_URL=postgresql://matin:YOUR_DB_PASSWORD@localhost:5432/matin_db
# متغير بديل لتجنب تعارض بيئات MySQL
MATIN_DATABASE_URL=postgresql://matin:YOUR_DB_PASSWORD@localhost:5432/matin_db

# --- المصادقة (إلزامي) ---
# استخدم: openssl rand -hex 64
JWT_SECRET=your_jwt_secret_here_min_64_chars
ENCRYPTION_KEY=your_encryption_key_here_64_hex_chars

# --- عنوان التطبيق (إلزامي) ---
NEXT_PUBLIC_APP_URL=https://your-domain.com

# --- Origins المسموح بها في الإنتاج (مهم أمنياً) ---
# أضف IP سيرفرك هنا بدل تضمينه في الكود
ALLOWED_ORIGINS=http://YOUR_SERVER_IP,http://YOUR_SERVER_IP:3000

# --- البريد الإلكتروني عبر Resend ---
# مطلوب لإرسال: بريد التسجيل، استعادة كلمة المرور، إشعارات الحصص
# إذا تُرك فارغاً: التطبيق يعمل لكن لا تُرسَل رسائل بريد (يظهر warning في السجلات)
#
# خطوات ربط الدومين مع Resend (لغير التقنيين):
#   1. سجّل في https://resend.com وافتح Domains
#   2. اضغط "Add Domain" وأدخل نطاقك (مثل: matin.ink)
#   3. ستحصل على 3 سجلات DNS — أضفها في لوحة الدومين لديك (Cloudflare أو نيم شيب):
#      - سجل TXT  اسمه: resend._domainkey   القيمة: تُعطيك إياها Resend
#      - سجل TXT  اسمه: _dmarc              القيمة: v=DMARC1; p=none;
#      - سجل MX  (اختياري للاستقبال فقط)
#   4. اضغط "Verify" في Resend وانتظر 5-30 دقيقة حتى يتحول إلى Verified
#   5. انسخ API Key من Settings > API Keys وضعه في RESEND_API_KEY أدناه
#   6. في RESEND_FROM_EMAIL استخدم عنواناً من نفس الدومين المُتحقق (مثل: no-reply@matin.ink)
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=no-reply@your-domain.com

# --- SMS - Unifonic (اختياري) ---
UNIFONIC_APP_SID=
UNIFONIC_SENDER_ID=Matin

# --- WhatsApp (اختياري) ---
WHATSAPP_API_KEY=
WHATSAPP_PHONE_ID=

# --- Firebase للإشعارات (اختياري) ---
FIREBASE_SERVER_KEY=

# --- الدفع عبر Moyasar ---
# Secret Key: يُستخدم في الـ backend فقط (إنشاء دفعة، التحقق، الـ webhook)
MOYASAR_API_KEY=sk_live_your_moyasar_secret_key
# Publishable Key: يُستخدم في الـ frontend (نموذج الدفع)
MOYASAR_PUBLISHABLE_KEY=pk_live_your_moyasar_publishable_key
# سر التحقق من صحة الـ webhook (من لوحة Moyasar > Webhooks)
MOYASAR_WEBHOOK_SECRET=your_moyasar_webhook_secret

# --- الدفع بالتقسيط عبر Tamara (اختياري) ---
TAMARA_API_KEY=your_tamara_api_key
TAMARA_MERCHANT_URL=https://your-domain.com

# --- OpenAI (اختياري) ---
OPENAI_API_KEY=sk-your_openai_key

# --- Google Maps (اختياري) ---
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# --- Zoom — المحاضرات المباشرة (اختياري) ---
ZOOM_API_KEY=
ZOOM_API_SECRET=
ZOOM_ACCOUNT_ID=

# --- Stripe — الدفع الدولي (اختياري) ---
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# --- Telr — الدفع المحلي (اختياري) ---
TELR_STORE_ID=
TELR_AUTH_KEY=
TELR_TEST_MODE=false

# --- Aramex — الشحن (اختياري) ---
ARAMEX_API_KEY=
ARAMEX_ACCOUNT_NUMBER=
ARAMEX_ACCOUNT_PIN=
ARAMEX_ACCOUNT_ENTITY=AMM
ARAMEX_ACCOUNT_COUNTRY=SA

# --- SMSA Express — الشحن المحلي (اختياري) ---
SMSA_API_KEY=
SMSA_PASS_KEY=

# --- DHL — الشحن الدولي (اختياري) ---
DHL_API_KEY=
DHL_API_SECRET=

# --- FedEx — الشحن الدولي (اختياري) ---
FEDEX_CLIENT_ID=
FEDEX_CLIENT_SECRET=

# --- SendGrid — الإيميلات (اختياري، بديل لـ Resend) ---
SENDGRID_API_KEY=

# --- Twilio — SMS (اختياري) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- AWS S3 — تخزين الملفات (اختياري) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=me-south-1
AWS_S3_BUCKET=

# --- تشفير الاختبارات (إلزامي إذا استخدمت ميزة الاختبارات) ---
# استخدم: openssl rand -hex 32
EXAM_ENCRYPTION_KEY=your_exam_encryption_key_32_chars

# --- رابط المنصة العام ---
NEXT_PUBLIC_URL=https://matin.ink

# --- سر مهام Cron (إلزامي للـ cron endpoints) ---
# استخدم: openssl rand -hex 32
# يُرسَل عبر header: x-cron-secret
CRON_SECRET=your_cron_secret_here

# --- بيئة التشغيل ---
# development | production | test
NODE_ENV=production
